# ────────────────────────────────────────────────────────────────────────
# Default provider is OpenAI / gpt-5-nano (see config.yaml > model).
# Only the key for the active provider is needed. Leave the other blank.
#
# Local:           copy this file to `.env` and paste your key.
# Streamlit Cloud: paste these in the app's Secrets panel (auto-load as env vars).
# GitHub Actions:  set as repo Secrets, reference via ${{ secrets.OPENAI_API_KEY }}.
#
# The dashboard (streamlit_app.py) only reads pre-computed CSVs in reports/ —
# no key needed to VIEW results. Keys are only needed to RUN new evaluations
# via `python evaluate.py`.
# ────────────────────────────────────────────────────────────────────────

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
